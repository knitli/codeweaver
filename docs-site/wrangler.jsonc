{
  "$schema": "node_modules/wrangler/config-schema.json",
  "assets": {
    "directory": "./public"
  },
  "compatibility_date": "2026-03-17",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "name": "codeweaver-docs",
  "observability": {
    "enabled": true
  },
  "placement": {
    "mode": "smart"
  },
  "upload_source_maps": false
}
