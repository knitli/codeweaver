{
  "chat.mcp.serverSampling": {
    "codeweaver/.vscode/mcp.json: codeweaver": {
      "allowedModels": [
        "copilot/claude-haiku-4.5",
        "copilot/claude-sonnet-4.5",
        "copilot/gemini-3-flash",
        "claude/claude-sonnet-4.5",
        "claude/claude-haiku-4.5",
        "sourcery/*",
        "gemini/gemini-3-flash",
        "gemini/gemini-3-pro"
      ]
    }
  },
  "debug.javascript.defaultRuntimeExecutable": {
    "pwa-node": "${userHome}/.local/share/mise/shims/node"
  },
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.languageServer": "None",
  "python.terminal.activateEnvironment": false,
  "ruff.interpreter": [
    "${userHome}/.local/share/mise/shims/python"
  ],
  "ruff.path": [
    "${userHome}/.local/share/mise/shims/ruff"
  ],
  "shellcheck.executablePath": "${userHome}/.local/share/mise/shims/shellcheck",
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.env.linux": {
    "CODEWEAVER_IN_VSCODE": "1",
    "ZDOTDIR": "${workspaceFolder}/.vscode/zsh"
  },
  "yaml.customTags": [
    "!ENV scalar",
    "!ENV sequence"
  ],
  "yaml.schemas": {
    "https://www.schemastore.org/sourcery_yaml_schema.json": [
      ".sourcery.yaml"
    ]
  },
  "yaml.validate": true
}