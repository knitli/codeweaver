{
  "servers": {
    "codeweaver": {
      "command": "uv",
      "args": [
        "run",
        "codeweaver",
        "server",
        "--transport",
        "stdio"
      ],
      "type": "stdio",
      "env": {
        "CODEWEAVER_PROJECT_PATH": "${env:CODEWEAVER_PROJECT_PATH}",
        "CODEWEAVER_VECTOR_STORE_URL": "${env:CODEWEAVER_VECTOR_STORE_URL}",
        "VOYAGE_API_KEY": "${env:VOYAGE_API_KEY}",
        "QDRANT__SERVICE__API_KEY": "${env:QDRANT__SERVICE__API_KEY}"
      }
    },
    "context7": {
      "args": [
        "--bun",
        "@upstash/context7-mcp@latest"
      ],
      "command": "bunx",
      "type": "stdio"
    },
    "morphLlmFastApply": {
      "args": [
        "--bun",
        "@morph-llm/morph-fast-apply@latest"
      ],
      "command": "bunx",
      "env": {
        "ALL_TOOLS": "false",
        "MORPH_API_KEY": "${env:MORPH_API_KEY}"
      },
      "type": "stdio"
    },
    "serena": {
      "args": [
        "run",
        "serena",
        "start-mcp-server",
        "--context",
        "agent"
      ],
      "command": "uv"
    },
    "tavily": {
      "args": [
        "--bun",
        "tavily-mcp@latest"
      ],
      "command": "bunx",
      "env": {
        "TAVILY_API_KEY": "${env:TAVILY_API_KEY}"
      }
    }
  }
}